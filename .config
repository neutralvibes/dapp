# ==============================================
#      d a p p    C o n f i g u r a t i o n
#===============================================

# Parent folder of docker application folders
DAPP_DIR=/opt/dapps

# Default editor to use
DAPP_EDITOR="nano"

# Whitelisted list operations for @all / @list / @list-file commands
# Use semicolon-separated docker compose subcommands.
#
# Allowed commands list
# Syntax:
#   - strict:cmd       (Exact match only)
#   - noflag:regex:cmd (Allows ARGS, but REJECTS if regex matches)
#   - flag:regex:cmd   (Allows ARGS, but ONLY if they match the regex)
#   - cmd              (Allows any ARGS)
#
# Examples:
#
#   noflag:(-f|--follow):logs        Ban 'logs' ARGS '-f' and '--follow'
#                                    Still allows any other ARGS.
#
#   strict:logs                      Allow 'logs' without any ARGS
#
#   flag:(-d|--hi|-p):cmd            Allows only '-d', '--hi' and '-p' for cmd
#                                    If only one ARG just use 'cmd -ARG'
#                                    e.g: 'up -d'
#
#   DAPP_LIST_SAFE="ps;up -d;down;restart"
#
#
DAPP_LIST_SAFE="pullup; ps; up -d; down; restart; pull; start; stop; top; noflag:(-f|--follow):logs"

# Whether to use `-f` or `cd` into folder
#
DAPP_RUN_MODE="cd"
