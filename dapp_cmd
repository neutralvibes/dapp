set -u
set -o pipefail

DAPP_VERSION="${DAPP_VERSION:-0.1.0}"

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)"
DAPP_CONFIG_FILE="$SCRIPT_DIR/.config"

DAPP_DIR="${DAPP_DIR:-}"

cfg_value() {
    local value="${1%\"}"
    echo "${value#\"}"
}

# Merge recognised values from .config file
# ignoring those already set
#
load_config() {
    local config_file="${1:?'Config file not specified'}"
    local valid_keys="${2:?'Config valid keys not specified'}"

    if [[ -f  "$config_file" ]]; then
        while IFS='=' read -r key value; do
            if [[ "$key" =~ ^($valid_keys)$ ]]; then
                if [[ -z "${!key:-}" ]]; then
                    printf -v "$key" "%s" "$(cfg_value "$value")"
                fi
            fi
        done < "$config_file"
    fi
}

load_config \
    "$DAPP_CONFIG_FILE" \
        "DAPP_DIR|DAPP_EDITOR|DAPP_LIST_SAFE|DAPP_RUN_MODE"

DAPP_DIR="${DAPP_DIR:-/opt/dapps}"
DAPP_RUN_MODE="${DAPP_RUN_MODE:-cd}"

DAPP_SELF_UPDATE_URL="${DAPP_SELF_UPDATE_URL:-https://raw.githubusercontent.com/neutralvibes/dapp/main/dapp_cmd}"
DAPP_APP_CFG=".dapp"

ORIG_CMD="$*"
ORIG_PARAM="$0"

# Verbose logging if DAPP_VERBOSE=1
log() {
    if [[ "${DAPP_VERBOSE:-}" == "1" ]]; then
        echo "$@"
    fi
}

err() {
    echo -e "❌ Error: $*" >&2
}

require_root() {

    if (( EUID != 0 )); then
        err 'This command must be run as root.\n'
        printf 'Try:\n'
        printf '\tsudo %q' "$(basename "${ORIG_PARAM}")"
        printf ' %q' "${ORIG_CMD[0]}"
        printf '\n'
        exit 1
    fi

}

yn_answer() {
   # honor non-interactive mode
   if [[ "${DAPP_ASSUME_YES:-}" == "1" ]]; then
       log "Auto-accepting prompt ($1)"
       return 0
   fi

   while true; do
        read -rp "$1 (Y/N) [N] ? " answer
        case "$answer" in
            [yY]) return 0 ;;
            *) return 1 ;;
        esac
    done
}

find_compose_file() {
    local dir="$1"

    for file in \
        compose.yml \
        compose.yaml \
        docker-compose.yml \
        docker-compose.yaml
    do
        [[ -f "$dir/$file" ]] && {
            echo "$file"
            return 0
        }
    done

    return 1
}

expand_shortcut_args() {
    local cmd="$1"
    shift

    case "$cmd" in
        b) SHORTCUT_ARGS=(build "$@");;
        d) SHORTCUT_ARGS=(down "$@");;
        e) SHORTCUT_ARGS=(exec "$@");;
        l) SHORTCUT_ARGS=(logs "$@");;
        lf) SHORTCUT_ARGS=(logs -f "$@");;
        k) SHORTCUT_ARGS=(kill "$@");;
        p) SHORTCUT_ARGS=(pull "$@");;
        r) SHORTCUT_ARGS=(restart "$@");;
        t) SHORTCUT_ARGS=(top "$@");;
        u) SHORTCUT_ARGS=(up -d "$@");;
        @bash) SHORTCUT_ARGS=(exec -it "$@" bash);;
        @sh) SHORTCUT_ARGS=(exec -it "$@" sh);;
        *) SHORTCUT_ARGS=("$cmd" "$@");;
    esac
}

list_apps() {
    [[ -d "$DAPP_DIR" ]] || (err "folder does not exist, ${DAPP_DIR} "; return 1)

    local dir
    local -a apps=()

    # Gather matching directories
    for dir in "$DAPP_DIR"/*; do
        [[ -d "$dir" ]] || continue

        if find_compose_file "$dir" >/dev/null 2>&1; then
            apps+=( "$(basename "$dir")" )
        fi
    done

    # Check array length instead of using a flag variable
    if [ ${#apps[@]} -eq 0 ]; then
        echo "NO-DOCKER-APPS-FOUND, under dapps folder ${DAPP_DIR}"
    else
        # Sort and display the found apps
        printf '%s\n' "${apps[@]}" | sort
    fi
}

get_all_apps() {
    local dir
    local -a apps=()

    [[ -d "$DAPP_DIR" ]] || return 0

    for dir in "$DAPP_DIR"/*; do
        [[ -d "$dir" ]] || continue

        if find_compose_file "$dir" >/dev/null 2>&1; then
            apps+=( "$(basename "$dir")" )
        fi
    done

    printf '%s\n' "${apps[@]}"
}

normalize_whitelist() {
    local value="$1"
    value="${value//$'\r'/}"
    value="${value//$'\n'/;}"
    echo "$value"
}

is_list_safe() {
    # params: whitelist command
    local whitelist="${1:? 'is_list_safe: Whitelist missing'}"
    shift
    local cmdline="$*"

    IFS=';' read -ra patterns <<< "${whitelist-?}"

    for pattern in "${patterns[@]}"; do
        # Strip leading/trailing whitespace
        pattern="${pattern#"${pattern%%[![:space:]]*}"}"
        pattern="${pattern%"${pattern##*[![:space:]]}"}"

        [[ -z "$pattern" ]] && continue

        # strict: Match only
        if [[ "$pattern" == strict:* ]]; then
            local actual_cmd="${pattern#strict:}"
            if [[ "$cmdline" =~ ^${actual_cmd}$ ]]; then
                return 0
            fi

        # noflag: Block-list ARGS
        elif [[ "$pattern" == noflag:* ]]; then
            local remainder="${pattern#noflag:}"
            local banned_flags="${remainder%%:*}"
            local actual_cmd="${remainder#*:}"

            if [[ "$cmdline" =~ ^${actual_cmd}([[:space:]]|$) ]]; then
                if [[ "$cmdline" =~ ([[:space:]]|^)${banned_flags}([[:space:]]|$) ]]; then
                    continue
                fi
                return 0
            fi

        # flag: Allow-list / ONLY these flags
        elif [[ "$pattern" == flag:* ]]; then
            local remainder="${pattern#flag:}"
            local allowed_flags="${remainder%%:*}"
            local actual_cmd="${remainder#*:}"

            if [[ "$cmdline" =~ ^${actual_cmd}([[:space:]]|$) ]]; then
                local args="${cmdline#"$actual_cmd"}"

                # no arguments left
                [[ -z "${args//[[:space:]]/}" ]] && return 0

                local safe=0
                read -ra arg_list <<< "$args"
                for arg in "${arg_list[@]}"; do
                    if [[ "$arg" == -* ]]; then
                        if [[ ! "$arg" =~ ^${allowed_flags}$ ]]; then
                            safe=1 # Banned flag!
                            break
                        fi
                    fi
                done

                if [[ $safe -eq 0 ]]; then
                    return 0
                fi
            fi

        # Basic Mode: cmd with any ARGS
        else
            if [[ "$cmdline" =~ ^${pattern}([[:space:]]|$) ]]; then
                return 0
            fi
        fi
    done

    return 1
}

list_help() {
    cat <<EOF
List operations:

These work on the selected APP folders under the DAPP_DIR parent.

  dapp @list-all COMMAND [ARGS]                     Run on all APPS (use care)
  dapp @list=APP1,APP2,APP3 COMMAND [ARGS]          Run on named APPS
  dapp @list-file=/path/to/file COMMAND [ARGS]      Run on named APPS in file
  dapp @status-save stopped PATH_TO_FILE            Save stopped APPS to file
  dapp @status-save running PATH_TO_FILE            Save running APPS to file
  dapp @list-help                                   Print this help

DAPP_LIST_SAFE:
    Semicolon-separated whitelist of allowed list commands.
    Defaults are set in '.config' file.
    Can be overriden by environment variable.

Current whitelist:
EOF
    local safe
    safe="$(normalize_whitelist "${DAPP_LIST_SAFE:-ps;up -d;down;restart;pull;start;stop}")"
    local IFS=';'
    local pattern
    for pattern in $safe; do
        pattern="${pattern#"${pattern%%[![:space:]]*}"}"
        pattern="${pattern%"${pattern##*[![:space:]]}"}"
        [[ -n "$pattern" ]] && printf '  %s\n' "$pattern"
    done
}

parse_app_list() {
    local list="$1"
    local app
    local IFS=','
    read -ra apps <<< "$list"
    for app in "${apps[@]}"; do
        app="${app#"${app%%[![:space:]]*}"}"
        app="${app%"${app##*[![:space:]]}"}"
        [[ -n "$app" ]] && printf '%s\n' "$app"
    done
}

read_apps_from_file() {
    local path="$1"
    if [[ "$path" != /* ]]; then
        path="$PWD/$path"
    fi
    if [[ ! -f "$path" ]]; then
        err "List file not found: $path"
        exit 1
    fi
    local app
    while IFS= read -r app; do
        app="${app#"${app%%[![:space:]]*}"}"
        app="${app%"${app##*[![:space:]]}"}"
        [[ -z "$app" || "$app" == \#* ]] && continue
        printf '%s\n' "$app"
    done < "$path"
}

get_apps_for_list_source() {
    local source="$1"
    case "$source" in
        @all)
            get_all_apps
            ;;
        @list=*)
            parse_app_list "${source#@list=}"
            ;;
        @list-file:*)
            read_apps_from_file "${source#@list-file:}"
            ;;
        @list-file=*)
            read_apps_from_file "${source#@list-file=}"
            ;;
        *)
            return 1
            ;;
    esac
}

run_list_command() {
    if (( $# < 2)); then
        echo "Missing  COMMAND"
        list_help
        exit 1
    fi

    local source="$1"
    shift
    local cmd="$1"
    shift
    if [[ -z "$cmd" ]]; then
        err "Missing COMMAND for list operation"
        exit 1
    fi
    expand_shortcut_args "$cmd" "$@"
    local list_command
    list_command="${SHORTCUT_ARGS[*]}"

    if ! is_list_safe "$DAPP_LIST_SAFE" "$list_command"; then
        err "Command not allowed for list operations: $list_command"
        err "Allowed operations are listed in DAPP_LIST_SAFE"
        exit 1
    fi

    local -a apps=()
    mapfile -t apps < <(get_apps_for_list_source "$source")

    if [[ ${#apps[@]} -eq 0 ]]; then
        err "No apps found for $source"
        exit 1
    fi

    require_compose
    local rc=0
    local app

    for app in "${apps[@]}"; do
        local app_dir="$DAPP_DIR/$app"

        if [[ ! -d "$app_dir" ]]; then
            err "Docker App '$app' not found under $DAPP_DIR"
            rc=1
            continue
        fi

        echo "==== $app ===="

        local compose_file
        compose_file="$(find_compose_file "$app_dir")" || {
            err "No compose file found in $app_dir"
            rc=1
            continue
        }

        if [[ -f "$app_dir/$DAPP_APP_CFG" ]]; then
            local not_in_whitelist=0

            while IFS='=' read -r key value; do
                case "$key" in
                    DAPP_LIST_SAFE)
                        local whitelist
                        whitelist="$(cfg_value "$value")"

                        if ! is_list_safe "$whitelist" "$list_command"; then
                            err "Command not allowed for list operations: $list_command"
                            err "Accepts only '$whitelist', blocked by: $app_dir/$DAPP_APP_CFG \n"
                            not_in_whitelist=1
                        fi
                        ;;
                esac
            done < "$app_dir/$DAPP_APP_CFG"

            (( not_in_whitelist )) && continue
        fi

        if [[ "${DAPP_RUN_MODE}" == "cd" ]]; then
            pushd "$app_dir" &>/dev/null || exit

            "${compose_cmd[@]}" "${SHORTCUT_ARGS[@]}" || rc=1

            popd  &>/dev/null || exit

        else
            "${compose_cmd[@]}" -f "$app_dir/$compose_file" "${SHORTCUT_ARGS[@]}" || rc=1
        fi

        echo -e "\n"

    done
    return "$rc"
}

save_status_to_file() {
    local target_status="$1"
    local output_file="$2"
    if [[ -z "$target_status" || -z "$output_file" ]]; then
        err "Usage: dapp @save-status (running|stopped) PATH_TO_FILE"
        exit 1
    fi
    if [[ "$target_status" != "running" && "$target_status" != "stopped" ]]; then
        err "Unsupported status '$target_status'. Use 'running' or 'stopped'."
        exit 1
    fi
    local path="$output_file"
    if [[ "$path" != /* ]]; then
        path="$PWD/$path"
    fi
    mkdir -p "$(dirname "$path")" || {
        err "Unable to create directory for $path"
        exit 1
    }
    : > "$path"
    require_compose
    local app
    local status
    local app_dir
    local compose_file
    local -a apps=()
    mapfile -t apps < <(get_all_apps)
    for app in "${apps[@]}"; do
        app_dir="$DAPP_DIR/$app"
        compose_file="$(find_compose_file "$app_dir")" || continue
        if "${compose_cmd[@]}" -f "$app_dir/$compose_file" ps -q 2>/dev/null | grep -q .; then
            status="running"
        else
            status="stopped"
        fi
        if [[ "$status" == "$target_status" ]]; then
            printf '%s\n' "$app" >> "$path"
        fi
    done
    echo "Saved apps with status '$target_status' to $path"
}

