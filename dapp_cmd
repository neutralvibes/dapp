# Preprocess global flags like --yes/-y to support non-interactive modes
NEW_ARGS=()
for arg in "$@"; do
    case "$arg" in
        --yes|-y)
            DAPP_ASSUME_YES=1
            ;;
        *)
            NEW_ARGS+=("$arg")
            ;;
    esac
done
if [ "${#NEW_ARGS[@]}" -gt 0 ]; then
    set -- "${NEW_ARGS[@]}"
else
    set --
fi

print_dapp_autocomplete() {
cat <<'EOF'
_dapp_completions() {
    local curr="${COMP_WORDS[COMP_CWORD]}"

    if [[ "$COMP_CWORD" -eq 1 ]]; then
        COMPREPLY=(
            $(compgen -W "$(dapp --list-apps) ls status" -- "$curr")
        )
        return
    fi

    if [[ "$COMP_CWORD" -eq 2 ]]; then
        COMPREPLY=(
            $(compgen -W "path edit ps up down restart start stop logs pull build config exec top images u d l r" -- "$curr")
        )
        return
    fi

    COMPREPLY=()
}

complete -F _dapp_completions dapp
EOF
}


set_dcd_target() {
    local fn='.bashrc'

    if (( $# == 0 )); then
        _DCD_TARGET="$HOME/${DCD_FILE:-$fn}"
    else
        local user=$1
        local userhome=$(getent passwd $user | cut -d: -f6)

        if [[ -z $userhome ]]; then
            # If empty
            err "User: $user has no home directory"
            return 1
        else
            _DCD_TARGET="$userhome/${DCD_FILE:-$fn}"
        fi
    fi

}

