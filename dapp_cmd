# Preprocess global flags like --yes/-y to support non-interactive modes
NEW_ARGS=()

for arg in "$@"; do
    case "$arg" in
        --yes|-y)
            DAPP_ASSUME_YES=1
            ;;
        *)
            NEW_ARGS+=("$arg")
            ;;
    esac
done

if [ "${#NEW_ARGS[@]}" -gt 0 ]; then
    set -- "${NEW_ARGS[@]}"
else
    set --
fi

print_dapp_autocomplete() {
cat <<'EOF'
_dapp_completions() {
    local curr="${COMP_WORDS[COMP_CWORD]}"
    local prev="${COMP_WORDS[COMP_CWORD-1]}"

    if [[ "$COMP_CWORD" -eq 1 ]]; then
        COMPREPLY=(
            $(compgen -W "$(dapp --list-apps) @ls @status @list-all @list= @list-file= @status-save @list-help -v -h --help --list-apps --apps-folder --autocomplete --install --uninstall --install-dcd --uninstall-dcd --self-update --yes" -- "$curr")
        )
        return
    fi

    if [[ "$COMP_CWORD" -eq 2 ]]; then
        if [[ "$prev" == "@save-status" ]]; then
            COMPREPLY=( $(compgen -W "running stopped" -- "$curr") )
            return
        fi

        if [[ "$prev" == @list-all || "$prev" == @list=* || "$prev" == @list-file:* || "$prev" == @list-file=* ]]; then
            COMPREPLY=(
                $(compgen -W "ps up down restart start stop logs pull build config exec top images u d l r" -- "$curr")
            )
            return
        fi

        COMPREPLY=(
            $(compgen -W "path edit ps up down restart start stop logs pull build config exec top images u d l r" -- "$curr")
        )
        return
    fi

    COMPREPLY=()
}

complete -F _dapp_completions dapp
EOF
}


set_dcd_target() {
    local fn='.bashrc'
    local user="${1:-$USER}"
    local userhome

    if [[ "$user" == "$USER" ]]; then
        userhome="$HOME"
    else
        userhome=$(getent passwd "$user" | cut -d: -f6)
        if [[ -z "$userhome" ]]; then
            err "User: $user has no home directory"
            return 1
        fi
    fi

    _DCD_TARGET="$userhome/${DCD_FILE:-$fn}"
}

set_dcd_var() {
        DCD_CMD="$(cat <<'EOF'
dcd() {                 #### AUTO GENERATED BY 'dapp' ####
    cd "$(dapp "$1" path)";
}

_dcd_completions() {    #### AUTO GENERATED BY 'dapp' ####

    local curr_word="${COMP_WORDS[COMP_CWORD]}"

    if [ "$COMP_CWORD" -eq 1 ]; then
        # local apps_folder="${_DAPP_FN_DIR:-/opt/dapps}"
        local apps_folder="$(dapp --apps-folder)"
        local apps=$(find "$apps_folder" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' 2>/dev/null)

        COMPREPLY=( $(compgen -W "$apps" -- "$curr_word") )
    else
        COMPREPLY=()
    fi
}

complete -F _dcd_completions dcd
EOF
)"
}

is_dcd_installed() {
    local BRC="$_DCD_TARGET"
    local m="dcd: present in ${BRC}"

    if grep -qF 'dcd() {' "$BRC"; then
        echo "${m}, true"
        log "Existing dcd block found in $BRC"
        return 0
    else
        echo "${m}, false"
        return 1
    fi
}

install_dcd() {
    if ! set_dcd_target; then
     exit 1
    fi

    if is_dcd_installed; then
        exit 1
    fi

    if (( EUID == 0 )); then
      local inject
      inject=$(cat << 'EOF'

---------------------- WARNING! ------------------
-- You are installing under 'root' (maybe sudo) --
--------------------------------------------------

'dcd' should ONLY be installed for the intended user.

If this is intentinal proceed below entering 'Y'

Otherwise select 'N' then:
    dapp --install-dcd          # for your user.

.
EOF
      )
    fi

    cat << EOF
=========================================
==========   'dcd' Installer   ==========
=========================================

EXAMPLES:
    dcd nginx           cd to DAPP_DIR/nginx

    dcd ng[TAB]         Completes 'dcd nginx'

The 'dcd' function is injected into a user '.bashrc' file.
${inject:-}
EOF

    if ! yn_answer "Install 'dcd' command"; then
        echo "Aborting..."
        exit 1
    fi

    set_dcd_var

    local line="$DCD_CMD"
    local BRC="$_DCD_TARGET"

    if [[ ! -f "$BRC" ]]; then
        local bn
        bn="$(basename "$BRC")"

        echo "You do not appear to have a ${bn} file."
        echo "dcd requires a ${bn} file to work."

        log "$BRC does not exist; creating"

        if ! yn_answer "Do you want me to create a ${bn} file for you"; then
            echo "Aborting..."
            exit 1
        fi

        if ! touch "$BRC"; then
            err "dcd: $BRC cannot be created, installation failed"
            exit 1
        else
            echo "dcd: Created, $BRC"
        fi
    fi

    log "Appending dcd function to $BRC"
    echo "dcd: Writing to $BRC"
    printf "%s\n" "" >> "$BRC"
    printf "%s\n" "$line" >> "$BRC"

    cat << EOF

Logout/in to use
    OR
        source ~/.bashrc  # For immediate use


✅ dcd function for user '$USER' installed to $BRC
EOF
}

uninstall_dcd() {
    local user="${1:-$USER}"

    set_dcd_target "$user"

    local BRC="$_DCD_TARGET"

    echo "dcd: Checking if installed for user, $user"

    if [[ -f "$BRC" ]]; then

        if ! is_dcd_installed; then
            return
        fi

        log "Removing dcd block from $BRC"

        if ! sed -i '/^dcd() {/,/complete -F _dcd_completions dcd/d' "$BRC";
        then
            err "dcd: Removal failure"
            exit 1
        fi

        echo "✅ dcd: Function removed for $user, user must logout to complete."
    else
        echo "dcd: $user has no file, $BRC"
    fi
}

download_content() {
    local url="$1"

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url"
        return $?
    fi

    if command -v wget >/dev/null 2>&1; then
        wget -qO- "$url"
        return $?
    fi

    return 1
}

download_latest() {
    local url="$1"
    local dst="$2"

    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url" -o "$dst"
        return $?
    fi

    if command -v wget >/dev/null 2>&1; then
        wget -qO "$dst" "$url"
        return $?
    fi

    return 1
}

remote_version() {
    local url="$1"
    download_content "$url" | grep -m1 '^DAPP_VERSION=' | sed -E 's/^DAPP_VERSION="([^"]+)".*/\1/' || true
}

version_compare() {
    local a b i
    local IFS=.
    read -ra a <<< "$1"
    read -ra b <<< "$2"

    for i in 0 1 2; do
        local ai=${a[i]:-0}
        local bi=${b[i]:-0}
        if (( ai < bi )); then
            return 1
        fi
        if (( ai > bi )); then
            return 2
        fi
    done

    return 0
}

self_update() {
    local url="${DAPP_SELF_UPDATE_URL:-}"

    if [[ -z "$url" || "$url" == *"<"* || "$url" == *">"* ]]; then
        err "DAPP_SELF_UPDATE_URL is not configured. Set it to the raw GitHub URL for this script."
        return 1
    fi

    local remote_ver
    remote_ver="$(remote_version "$url")" || {
        err "Unable to fetch remote version from $url"
        return 1
    }

    if [[ -z "$remote_ver" ]]; then
        err "Could not parse remote version from $url"
        return 1
    fi

    version_compare "$DAPP_VERSION" "$remote_ver"
    case $? in
        0)
            echo "✅ dapp is already up to date (version $DAPP_VERSION)"
            return 0
            ;;
        2)
            echo "✅ Remote version ($remote_ver) is not newer than current version ($DAPP_VERSION)"
            return 0
            ;;
    esac

    if [[ "${DAPP_ALLOW_USER_INSTALL:-}" != "1" ]]; then
        require_root
    fi

    local target
    local tmp

    target="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"

    tmp="$(mktemp /tmp/dapp-self-update.XXXXXX)" || {
        err "Failed to create temporary file"
        return 1
    }

    if ! download_latest "$url" "$tmp"; then
        rm -f "$tmp"
        err "Failed to download latest version"
        return 1
    fi

    if ! grep -q '^#!/usr/bin/env bash' "$tmp"; then
        rm -f "$tmp"
        err "Downloaded file does not look like a valid script"
        return 1
    fi

    chmod +x "$tmp"
    mv "$tmp" "$target"

    echo "✅ Updated dapp from version $DAPP_VERSION to $remote_ver at $target"
}

get_dapp_install_target() {
    if [[ -n "${DAPP_INSTALL_TARGET:-}" ]]; then
        echo "$DAPP_INSTALL_TARGET"
    elif [[ "${DAPP_ALLOW_USER_INSTALL:-}" == "1" ]]; then
        echo "${HOME}/.local/bin/dapp"
    else
        echo "/usr/local/bin/dapp"
    fi
}

get_completion_dir() {
    if [[ -n "${DAPP_COMPLETION_DIR:-}" ]]; then
        echo "$DAPP_COMPLETION_DIR"
        return
    fi

    if [[ "${DAPP_ALLOW_USER_INSTALL:-}" == "1" ]]; then
        echo "${XDG_DATA_HOME:-$HOME/.local/share}/bash-completion/completions"
        return
    fi

    echo "/usr/share/bash-completion/completions"
}

install_self() {
    local target
    target="$(get_dapp_install_target)"

    local completion_dir
    completion_dir="$(get_completion_dir)"

    local src

    # allow non-root installs for testing via DAPP_ALLOW_USER_INSTALL=1
    if [[ "${DAPP_ALLOW_USER_INSTALL:-}" != "1" ]]; then
        require_root
    else
        log "User-mode install enabled (DAPP_ALLOW_USER_INSTALL=1)"
    fi

    src="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"

    if ! mkdir -p "$(dirname "$target")"; then
        err "Unable to create,  $(dirname "$target")"
        exit 1
    fi

    if ! ln -sfn "$src" "$target"; then
        err "Unable to link, $src->$target"
        exit 1
    fi

    if ! mkdir -p "$completion_dir"; then
        err "Unable to create completion directory, $completion_dir"
        exit 1
    fi

    # Run 'dapp --autocomplete' then place code in completion folder
    if ! "$target" --autocomplete | tee "$completion_dir/dapp" >/dev/null; then
        err "Warning: Autocomplete registration failed; continuing without completion."
        err "Check permissions for $completion_dir or set DAPP_COMPLETION_DIR to a writable path."
    fi

    cat << EOF

Default uses DAPP_DIR='/opt/dapps' as parent for appication sub-folders

    Edit the '/opt/dapp_cmd/.config'     # To confiure 'DAPP_DIR' if differs

USAGE:
    dapp -h                     For further info
    dapp --apps-folder          Print configured parent folder (via 'DAPP_DIR')


CONSIDER 'dcd' for a quick 'cd' to an apps folder.

    dcd niginx                  cd to DAPP_DIR/nginx

    Installation:
        dapp --install-dcd


✅ dapp installed successfully.
EOF

}

uninstall_self() {
    # allow non-root uninstall for testing via DAPP_ALLOW_USER_INSTALL=1
    if [[ "${DAPP_ALLOW_USER_INSTALL:-}" != "1" ]]; then
        require_root
    else
        log "User-mode uninstall enabled (DAPP_ALLOW_USER_INSTALL=1)"
    fi

    # remove dcd installations first
    uninstall_dcd

    if [[ -n "${SUDO_USER:-}" ]]; then
        uninstall_dcd "$SUDO_USER"
    fi

    # Now remove dapp
    local target
    local completion_dir

    target="$(get_dapp_install_target)"
    completion_dir="$(get_completion_dir)"

    if ! rm -f "$target"; then
        err "dapp uninstall failed to remove, $target"
        exit 1
    fi

    if ! rm -f "$completion_dir/dapp"; then
        err "Failed to remove completion code , $completion_dir/dapp"
        exit 1
    fi
    complete -r dapp 2>&1 /dev/null
    echo "✅ dapp uninstall completed successfully."
}

edit_app() {
    local app="$1"
    local dir="$DAPP_DIR/$app"

    [[ -d "$dir" ]] || {
        err "Docker App '$app' not found under $DAPP_DIR"
        return 1
    }

    local compose
    compose="$(find_compose_file "$dir")" || {
        err "No compose file found"
        return 1
    }

    "${DAPP_EDITOR:-nano}" "$dir/$compose"
}

require_compose() {
    if [[ -n "${compose_cmd[*]:-}" ]]; then
        return 0
    fi

    if docker compose version >/dev/null 2>&1; then
        compose_cmd=(docker compose)
        return 0
    fi

    if docker-compose version >/dev/null 2>&1; then
        compose_cmd=(docker-compose)
        return 0
    fi

    err "Docker Compose not found"
    exit 1
}

status_all() {
    require_compose

    printf "%-25s %s\n" "APP" "STATUS"

    local app

    while read -r app; do
        local dir="$DAPP_DIR/$app"
        local compose

        compose="$(find_compose_file "$dir")" || continue

        if "${compose_cmd[@]}" -f "$dir/$compose" ps -q 2>/dev/null | grep -q .; then
            printf "%-25s running\n" "$app"
        else
            printf "%-25s stopped\n" "$app"
        fi
    done < <(list_apps)
}

